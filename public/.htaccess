# ------------------------------------------------------------------------------
# Purnova Production Web Server Configuration (.htaccess)
# Designed for Hostinger Shared Hosting (Apache)
# ------------------------------------------------------------------------------

# 1. SPA Routing: Redirect all requests to index.html for React Router
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # If the requested filename is an actual file or directory, serve it directly
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-l
  
  # Rewrite all other requests to index.html
  RewriteRule . /index.html [L]
</IfModule>

# 2. Gzip/Deflate Compression: Optimize bandwidth and load speed
<IfModule mod_deflate.c>
  # Force compression for standard web text files
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/x-javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE application/rss+xml
  AddOutputFilterByType DEFLATE application/atom+xml
  
  # Force compression for font files and vector graphics
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE image/x-icon
  AddOutputFilterByType DEFLATE application/vnd.ms-fontobject
  AddOutputFilterByType DEFLATE application/x-font
  AddOutputFilterByType DEFLATE application/x-font-opentype
  AddOutputFilterByType DEFLATE application/x-font-otf
  AddOutputFilterByType DEFLATE application/x-font-truetype
  AddOutputFilterByType DEFLATE application/x-font-ttf
  AddOutputFilterByType DEFLATE font/opentype
  AddOutputFilterByType DEFLATE font/otf
  AddOutputFilterByType DEFLATE font/ttf
  AddOutputFilterByType DEFLATE font/woff
  AddOutputFilterByType DEFLATE font/woff2
</IfModule>

# 3. Cache-Control & Expires Headers: Cache static assets aggressively, never cache index.html
<IfModule mod_expires.c>
  ExpiresEngine On
  ExpiresDefault "access plus 1 month"

  # Force no-cache on entry points so updates are discovered immediately
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType application/json "access plus 0 seconds"
  ExpiresByType application/xml "access plus 0 seconds"
  ExpiresByType text/xml "access plus 0 seconds"

  # Static Assets (Vite appends content hashes to assets, making them safe to cache forever)
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
  
  # Media Files
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"

  # Web Fonts
  ExpiresByType font/truetype "access plus 1 year"
  ExpiresByType font/opentype "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Custom Headers to enforce caching rules
<IfModule mod_headers.c>
  # 1-year immutable caching for static assets
  <FilesMatch "\.(css|js|jpg|jpeg|png|gif|webp|svg|ico|woff|woff2|otf|ttf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Explicitly tell browsers to never cache index.html or config files
  <FilesMatch "\.(html|json)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires 0
  </FilesMatch>
</IfModule>

# 4. Security Headers: Enhance application security
<IfModule mod_headers.c>
  # Prevent MIME type sniffing
  Header set X-Content-Type-Options "nosniff"

  # Prevent clickjacking attacks (only frame within same origin)
  Header set X-Frame-Options "SAMEORIGIN"

  # Enable XSS filtering in browsers
  Header set X-XSS-Protection "1; mode=block"

  # Referrer policy control
  Header set Referrer-Policy "strict-origin-when-cross-origin"

  # HTTP Strict Transport Security (HSTS) - forces SSL connections (Hostinger has free SSL)
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>
